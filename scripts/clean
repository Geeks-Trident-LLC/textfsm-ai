#!/usr/bin/env bash
set -euo pipefail

echo "Cleaning Python caches and build artifacts..."

# __pycache__ and *.pyc
find . -type d -name "__pycache__" -exec rm -rf {} + 2>/dev/null
find . -type f -name "*.pyc" -delete 2>/dev/null

# pytest cache
find . -type d -name ".pytest_cache" -exec rm -rf {} + 2>/dev/null

# Ruff cache
find . -type d -name ".ruff_cache" -exec rm -rf {} + 2>/dev/null
find . -type d -name ".ruffcache" -exec rm -rf {} + 2>/dev/null

# tox environments
find . -type d -name ".tox" -exec rm -rf {} + 2>/dev/null

# mymy cache
find . -type d -name ".mypy_cache" -exec rm -rf {} + 2>/dev/null

# Coverage output
find . -type d -name "htmlcov" -exec rm -rf {} + 2>/dev/null
find . -type f -name ".coverage" -delete 2>/dev/null
find . -type f -name "coverage.xml" -delete 2>/dev/null

# Packaging metadata
find . -type d -name "*.egg-info" -exec rm -rf {} + 2>/dev/null

# Build artifacts
find . -type d -name "build" -exec rm -rf {} + 2>/dev/null
find . -type d -name "dist" -exec rm -rf {} + 2>/dev/null
find . -type f -name "*.whl" -delete 2>/dev/null
find . -type f -name "*.tar.gz" -delete 2>/dev/null

echo "Cleanup complete."
