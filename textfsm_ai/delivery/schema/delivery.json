{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "title": "DeliveryPackage",
    "type": "object",
    "properties": {
        "mode": {
            "type": "string",
            "enum": [
                "quiet",
                "default",
                "info",
                "debug"
            ]
        },
        "general": {
            "type": [
                "object",
                "null"
            ],
            "properties": {
                "textfsm_version": {
                    "type": "string"
                },
                "textfsm_ai_version": {
                    "type": "string"
                },
                "model": {
                    "type": "string"
                },
                "created_at": {
                    "type": "string",
                    "format": "date-time"
                }
            },
            "required": [
                "textfsm_version",
                "textfsm_ai_version",
                "model",
                "created_at"
            ]
        },
        "template": {
            "type": "object",
            "properties": {
                "canonical_template": {
                    "type": "string"
                },
                "human_template_dsl": {
                    "type": "string"
                }
            },
            "required": [
                "canonical_template",
                "human_template_dsl"
            ]
        },
        "explanation": {
            "type": [
                "object",
                "null"
            ],
            "properties": {
                "variable_definitions": {
                    "type": "string"
                },
                "llm_parsing_explanation": {
                    "type": "string"
                },
                "template_generation_explanation": {
                    "type": "string"
                }
            },
            "required": [
                "variable_definitions",
                "llm_parsing_explanation",
                "template_generation_explanation"
            ]
        },
        "status": {
            "type": "object",
            "properties": {
                "state": {
                    "type": "string"
                },
                "warnings": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    }
                },
                "errors": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    }
                }
            },
            "required": [
                "state",
                "warnings",
                "errors"
            ]
        },
        "usage": {
            "type": [
                "object",
                "null"
            ],
            "properties": {
                "input_tokens": {
                    "type": "integer",
                    "minimum": 0
                },
                "output_tokens": {
                    "type": "integer",
                    "minimum": 0
                },
                "total_tokens": {
                    "type": "integer",
                    "minimum": 0
                },
                "estimated_cost": {
                    "type": [
                        "number",
                        "null"
                    ]
                },
                "duration_ms": {
                    "type": [
                        "integer",
                        "null"
                    ],
                    "minimum": 0
                }
            },
            "required": [
                "input_tokens",
                "output_tokens",
                "total_tokens"
            ]
        },
        "debug": {
            "type": [
                "object",
                "null"
            ],
            "properties": {
                "raw_llm_output": {
                    "type": [
                        "string",
                        "null"
                    ]
                },
                "cleaned_template": {
                    "type": [
                        "string",
                        "null"
                    ]
                },
                "canonical_template_internal": {
                    "type": [
                        "string",
                        "null"
                    ]
                },
                "machine_dsl": {
                    "type": "object"
                },
                "human_template_dsl_internal": {
                    "type": [
                        "string",
                        "null"
                    ]
                },
                "recognizer_dsl": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    }
                },
                "validation_log": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    }
                },
                "canonicalization_log": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    }
                },
                "literal_regex_trace": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    }
                }
            }
        }
    },
    "required": [
        "mode",
        "template",
        "status"
    ]
}